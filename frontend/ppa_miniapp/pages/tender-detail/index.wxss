.detail-page {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.hero-card,
.section-card {
  padding: 32rpx;
}

.hero-top {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.detail-title {
  flex: 1;
  line-height: 1.5;
}

.detail-summary {
  line-height: 1.7;
}

.section-title {
  margin-bottom: 24rpx;
  font-size: 30rpx;
  font-weight: 700;
  color: #0f172a;
}

.detail-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 20rpx 16rpx;
}

.detail-item {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.extra-block {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  margin-top: 20rpx;
}

.detail-label {
  font-size: 24rpx;
}

.multiline {
  white-space: pre-wrap;
  line-height: 1.7;
}

.plain-announcement {
  display: block;
  white-space: pre-wrap;
  line-height: 1.8;
}

.source-link {
  display: block;
  margin-bottom: 20rpx;
  word-break: break-all;
  color: #0f766e;
}

.action-row {
  padding-bottom: 32rpx;
}
