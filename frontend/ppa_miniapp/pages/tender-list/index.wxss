.list-page {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.reminder-banner {
  padding: 28rpx;
  border: 1px solid #bbf7d0;
  background: #f0fdf4;
}

.reminder-banner__header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.reminder-banner__title {
  font-size: 30rpx;
  font-weight: 700;
  color: #166534;
}

.reminder-banner__description {
  display: block;
  line-height: 1.7;
  color: #166534;
}

.reminder-banner__action {
  margin-top: 20rpx;
}

.filter-card {
  padding: 32rpx;
}

.filter-header {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.filter-header__top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.filter-header__action {
  width: auto;
  min-width: 180rpx;
  height: 72rpx;
  padding: 0 28rpx;
  font-size: 26rpx;
  line-height: 72rpx;
}

.picker-row {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.picker-field {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.picker-value {
  height: 84rpx;
  padding: 0 24rpx;
  border-radius: 20rpx;
  background: #f8fafc;
  border: 2rpx solid #cbd5e1;
  line-height: 84rpx;
}

.list-stack {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.tender-card {
  padding: 28rpx;
}

.card-header {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.tender-title {
  flex: 1;
  font-size: 32rpx;
  font-weight: 700;
  color: #0f172a;
  line-height: 1.5;
}

.meta-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
}

.meta-item {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.meta-label {
  font-size: 24rpx;
}
