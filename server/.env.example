PORT=3001
NODE_ENV=development

# SQLite 数据库文件路径（仅在显式使用 sqlite 时需要）
# 自动化 / E2E 测试应设置到临时数据库，避免污染开发数据
# DB_PATH=/absolute/path/to/ppa.e2e.db

# 数据库类型（默认 postgres；如需本地 SQLite 兼容可显式设置 sqlite）
# DB_TYPE=postgres

# Supabase PostgreSQL 连接串（仅在 DB_TYPE=postgres 时需要）
# 不要提交真实值；Supabase 控制台 Database -> Connection string 获取
# Node pg 当前建议不要把 sslmode=require 放进 URL；用下面的 PGSSLMODE=require 触发 SSL 配置
# Direct connection:
# DATABASE_URL=postgresql://postgres:[PASSWORD]@db.xxx.supabase.co:5432/postgres
# Transaction pooler:
# DATABASE_URL=postgresql://postgres.xxx:[PASSWORD]@aws-x-region.pooler.supabase.com:6543/postgres

# PostgreSQL SSL 模式（Supabase 通常要求 require）
# PGSSLMODE=require

# 导出日志开关（默认开启）
EXPORT_LOG_ENABLED=true

# 导出日志目录（可选，默认为 server/logs/export）
# EXPORT_LOG_DIR=/absolute/path/to/export/logs

# CloudBase 服务端推送配置
# CLOUDBASE_ENV_ID=cloud1-xxxxxxxx
# CLOUDBASE_APIKEY=your-cloudbase-server-api-key
# CLOUDBASE_SECRET_ID=your-secret-id
# CLOUDBASE_SECRET_KEY=your-secret-key
# MINIAPP_PUSH_SECRET_KEY=replace-with-your-push-secret
MINIAPP_PUSH_SECRET_KEY=ppa-miniapp-push-20260316-demo
# MINIAPP_PUSH_FUNCTION_NAME=upsertTenderBySourceId
