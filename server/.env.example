PORT=3001
NODE_ENV=development

# 导出日志开关（默认开启）
EXPORT_LOG_ENABLED=true

# 导出日志目录（可选，默认为 server/logs/export）
# EXPORT_LOG_DIR=/absolute/path/to/export/logs

# CloudBase 服务端推送配置
# CLOUDBASE_ENV_ID=cloud1-xxxxxxxx
# CLOUDBASE_APIKEY=your-cloudbase-server-api-key
# CLOUDBASE_SECRET_ID=your-secret-id
# CLOUDBASE_SECRET_KEY=your-secret-key
# MINIAPP_PUSH_SECRET_KEY=replace-with-your-push-secret
MINIAPP_PUSH_SECRET_KEY=ppa-miniapp-push-20260316-demo
# MINIAPP_PUSH_FUNCTION_NAME=upsertTenderBySourceId
