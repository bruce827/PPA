{
  "info": {
    "name": "PPA 项目评估系统 API",
    "description": "PPA (Project Portfolio Assessment) 项目评估系统API集合\n\n## 使用说明\n1. 确保后端服务器运行在 http://localhost:3001\n2. 使用环境变量 `{{base_url}}` 和 `{{api_prefix}}` 配置请求地址\n3. 所有API响应格式统一为 `{success: boolean, data: any, error?: string}`",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "PPA-Team"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:3001",
      "type": "string"
    },
    {
      "key": "api_prefix",
      "value": "/api",
      "type": "string"
    },
    {
      "key": "project_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "template_id",
      "value": "",
      "type": "string"
    }
  ],
