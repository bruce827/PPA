      "description": "系统状态检查相关接口",
      "item": [
        {
          "name": "系统健康检查",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}{{api_prefix}}/health",
              "host": ["{{base_url}}"],
              "path": ["{{api_prefix}}", "health"]
            },
            "description": "检查系统运行状态和数据库连接\n\n**响应字段:**\n- `status`: 系统状态 (healthy/degraded/unhealthy)\n- `uptime`: 运行时间（秒）\n- `database`: 数据库连接状态\n- `memory`: 内存使用情况"
          },
          "response": []
        }
      ]
    },
